        "\n",
        "# Fit auto_arima to find the best SARIMAX order\n",
        "# We're passing the exogenous variables as well\n",
        "auto_model = pm.auto_arima(\n",
        "    ts_train['Weekly_Sales'],\n",
        "    exog=exog_train,\n",
        "    start_p=1, start_q=1,\n",
        "    test='adf',       # Use ADF test to determine 'd'\n",
        "    max_p=3, max_q=3,\n",
